<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="แบบทดสอบความล้าตา"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <TextView
            android:id="@+id/textQuestion1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:text="1. ตาแห้งหรือแสบตา" />

        <RadioGroup
            android:id="@+id/radioGroup1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp">
            <RadioButton android:id="@+id/q1_0" android:text="ไม่เลย" />
            <RadioButton android:id="@+id/q1_1" android:text="บางครั้ง" />
            <RadioButton android:id="@+id/q1_2" android:text="บ่อย" />
            <RadioButton android:id="@+id/q1_3" android:text="ประจำ" />
        </RadioGroup>

        <TextView
            android:id="@+id/textQuestion2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:text="2. ปวดหัวหลังจากใช้หน้าจอนานๆ" />

        <RadioGroup
            android:id="@+id/radioGroup2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp">
            <RadioButton android:id="@+id/q2_0" android:text="ไม่เลย" />
            <RadioButton android:id="@+id/q2_1" android:text="บางครั้ง" />
            <RadioButton android:id="@+id/q2_2" android:text="บ่อย" />
            <RadioButton android:id="@+id/q2_3" android:text="ประจำ" />
        </RadioGroup>

        <TextView
            android:id="@+id/textQuestion3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:text="3. มองเห็นภาพเบลอหรือโฟกัสยาก" />

        <RadioGroup
            android:id="@+id/radioGroup3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp">
            <RadioButton android:id="@+id/q3_0" android:text="ไม่เลย" />
            <RadioButton android:id="@+id/q3_1" android:text="บางครั้ง" />
            <RadioButton android:id="@+id/q3_2" android:text="บ่อย" />
            <RadioButton android:id="@+id/q3_3" android:text="ประจำ" />
        </RadioGroup>

        <TextView
            android:id="@+id/textQuestion4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:text="4. ปวดคอ/บ่า/ไหล่ขณะใช้หน้าจอ" />

        <RadioGroup
            android:id="@+id/radioGroup4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp">
            <RadioButton android:id="@+id/q4_0" android:text="ไม่เลย" />
            <RadioButton android:id="@+id/q4_1" android:text="บางครั้ง" />
            <RadioButton android:id="@+id/q4_2" android:text="บ่อย" />
            <RadioButton android:id="@+id/q4_3" android:text="ประจำ" />
        </RadioGroup>

        <TextView
            android:id="@+id/textQuestion5"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:text="5. รู้สึกง่วงหรือล้าตาระหว่างวัน" />

        <RadioGroup
            android:id="@+id/radioGroup5"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="28dp">
            <RadioButton android:id="@+id/q5_0" android:text="ไม่เลย" />
            <RadioButton android:id="@+id/q5_1" android:text="บางครั้ง" />
            <RadioButton android:id="@+id/q5_2" android:text="บ่อย" />
            <RadioButton android:id="@+id/q5_3" android:text="ประจำ" />
        </RadioGroup>

        <Button
            android:id="@+id/btnSubmitTest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="18dp"
            android:textSize="16sp"
            android:text="ดูผลลัพธ์" />

    </LinearLayout>

</ScrollView>
